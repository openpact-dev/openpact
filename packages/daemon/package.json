{
  "name": "@openpact/daemon",
  "version": "0.1.2",
  "description": "OpenPact daemon: Autobase + Hyperswarm + REST on localhost:7666",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://openpact.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openpact-dev/openpact.git",
    "directory": "packages/daemon"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node scripts/finalise-esm.mjs",
    "build:clean": "rm -rf dist && npm run build",
    "validate": "publint --strict",
    "prepublishOnly": "npm run build:clean && npm run validate",
    "test": "NODE_OPTIONS='--import tsx' brittle 'test/{unit,integration}/**/*.test.ts'"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autobase": "^7.27.3",
    "b4a": "^1.6.7",
    "corestore": "^7.9.2",
    "fastify": "^5.8.5",
    "hyperbee": "^2.27.3",
    "hypercore": "^11.28.1",
    "hypercore-crypto": "^3.6.1",
    "hyperswarm": "^4.17.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "hyperdht": "^6.30.0",
    "publint": "^0.2.12"
  }
}
