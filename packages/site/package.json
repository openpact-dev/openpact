{
  "name": "@openpact/site",
  "version": "0.1.1",
  "private": true,
  "description": "Marketing + docs site for openpact.dev",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://openpact.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openpact-dev/openpact.git",
    "directory": "packages/site"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-agent-skills.mjs && tsx scripts/generate-markdown.mts",
