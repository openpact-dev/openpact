    "preview": "vite preview --port 7668"
  },
  "dependencies": {
    "mermaid": "^11.4.1",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/turndown": "^5.0.5",
    "node-html-parser": "^7.0.1",
    "preact-render-to-string": "^6.5.13",
    "tailwindcss": "^4.2.2",
    "turndown": "^7.2.0",
    "vite": "^8.0.8"
  }
