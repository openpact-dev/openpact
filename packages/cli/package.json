{
  "name": "@openpact/cli",
  "version": "0.1.3",
  "description": "OpenPact CLI: the openpact command-line interface for the local daemon.",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://openpact.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openpact-dev/openpact.git",
    "directory": "packages/cli"
  },
  "type": "commonjs",
  "main": "dist/cjs/bin.js",
  "types": "dist/cjs/bin.d.ts",
  "bin": {
    "openpact": "bin/openpact.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json",
    "build:clean": "rm -rf dist && npm run build",
    "validate": "publint --strict",
    "prepublishOnly": "npm run build:clean && npm run validate",
    "test": "NODE_OPTIONS='--import tsx' brittle 'test/{unit,e2e}/**/*.test.ts'"
  },
  "dependencies": {
    "@openpact/daemon": "^0.1.1",
    "@openpact/dashboard": "^0.1.1",
    "@openpact/sdk": "^0.1.1",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "publint": "^0.2.12"
  }
}
