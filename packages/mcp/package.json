{
  "name": "@openpact/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the OpenPact daemon",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://openpact.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openpact-dev/openpact.git",
    "directory": "packages/mcp"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "bin": {
    "openpact-mcp": "bin/openpact-mcp.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json",
    "build:clean": "rm -rf dist && npm run build",
    "validate": "publint --strict",
    "prepublishOnly": "npm run build:clean && npm run validate",
    "test": "NODE_OPTIONS='--import tsx' brittle 'test/{unit,integration}/**/*.test.ts'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openpact/sdk": "^0.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@openpact/daemon": "^0.1.0",
    "publint": "^0.2.12"
  }
}
