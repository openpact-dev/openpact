{
  "name": "@openpact/dashboard",
  "version": "0.1.3",
  "description": "Web dashboard for the OpenPact daemon (served on localhost:7667)",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://openpact.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openpact-dev/openpact.git",
    "directory": "packages/dashboard"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && npm run build:server && npm run build:browser",
    "build:server": "tsc -p tsconfig.server.json",
    "build:browser": "vite build",
    "build:clean": "rm -rf dist && npm run build",
    "validate": "publint --strict",
    "prepublishOnly": "npm run build:clean && npm run validate",
    "dev": "vite",
    "size": "size-limit",
    "test": "NODE_OPTIONS='--import tsx' brittle 'test/{unit,integration}/**/*.test.ts'",
    "test:unit": "NODE_OPTIONS='--import tsx' brittle 'test/unit/**/*.test.ts'",
    "test:hooks": "vitest run",
    "test:ui": "playwright test"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/static": "^9.1.0",
    "@openpact/sdk": "^0.1.0",
    "dompurify": "^3.4.0",
    "fastify": "^5.8.5",
    "marked": "^16.4.2",
    "preact": "^10.29.1",
    "preact-router": "^4.1.2",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@openpact/daemon": "^0.1.0",
    "@playwright/test": "^1.59.1",
    "publint": "^0.2.12",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/preact": "^3.2.4",
    "jsdom": "^29.0.2",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
