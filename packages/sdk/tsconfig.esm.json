{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "es2022",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "dist/esm",
    "rootDir": "src",
    "declaration": true,
    "noEmit": false,
    "sourceMap": true,
    "removeComments": false
  },
  "include": ["src/**/*"],
  "exclude": ["test/**/*", "node_modules", "dist"]
}
